# =============================================
# Task Manager Backend — Environment Variables
# =============================================

# Server
PORT=5000

# MongoDB (points to the Docker container)
MONGO_URI=mongodb://root:rootpassword@localhost:27017/taskmanager?authSource=admin

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_abc123!

# Admin Invite Token (used during registration to grant admin role)
ADMIN_INVITE_TOKEN=123456

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173
